            <Shape><Polygon POINTS="224 1904 224 1921 2251 1921 2251 1904 2251 1874 224 1874 224 1904"/></Shape>
            <String CONTENT="человека, а тем более барина, - подумал он про себя, - и продал, непременно продал, пари"
                    HPOS="224"
                    VPOS="1874"
                    WIDTH="2027"
