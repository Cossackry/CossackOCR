            <String CONTENT="жалованье да где-нибудь потаскаться, вот это их дело. Сказал бы им всем кое-что, да уж"
                    HPOS="224"
                    VPOS="2747"
                    WIDTH="2027"
                    HEIGHT="49"
                    WC="0.9999664668426957"></String>
          </TextLine>
          <TextLine ID="eSc_line_00e28412"
