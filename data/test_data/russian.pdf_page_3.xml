            <Shape><Polygon POINTS="226 2340 226 2358 2249 2354 2251 2336 2246 2309 224 2311 226 2340"/></Shape>
            <String CONTENT="господину Голядкину, были тоже, с своей стороны, в крайнем недоумении, встретив таким"
                    HPOS="224"
                    VPOS="2309"
                    WIDTH="2027"
                    HEIGHT="49"
