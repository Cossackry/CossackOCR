        <TextBlock ID="eSc_dummyblock_">
          <TextLine ID="eSc_line_a6beb68c"
                    TAGREFS="LT1379"
                    BASELINE="233 280 725 280" 
                    HPOS="233"
                    VPOS="251"
                    WIDTH="492"
                    HEIGHT="43">
            <Shape><Polygon POINTS="233 257 233 280 233 294 725 294 725 280 725 251 239 251 233 257"/></Shape>
            <String CONTENT="- И сапоги принесли."
                    HPOS="233"
                    VPOS="251"
                    WIDTH="492"
                    HEIGHT="43"
                    WC="0.9963173151016236"></String>
          </TextLine>
          <TextLine ID="eSc_line_4d2d4cbd"
                    TAGREFS="LT1379"
                    BASELINE="232 343 1485 339" 
                    HPOS="230"
                    VPOS="302"
                    WIDTH="1255"
                    HEIGHT="54">
            <Shape><Polygon POINTS="1477 317 1464 307 292 302 290 302 230 311 232 343 232 356 1483 352 1485 339 1481 319 1477 317"/></Shape>
            <String CONTENT="- Болван! не можешь сказать принесли-с. Давай их сюда."
                    HPOS="230"
                    VPOS="302"
                    WIDTH="1255"
                    HEIGHT="54"
                    ></String>
          </TextLine>
          <TextLine ID="eSc_line_84e6f11d"
                    TAGREFS="LT1379"
                    BASELINE="224 405 2249 401" 
                    HPOS="222"
                    VPOS="370"
                    WIDTH="2027"
                    HEIGHT="52">
            <Shape><Polygon POINTS="2230 372 2210 372 2191 372 2171 372 2152 372 2132 372 2113 372 2093 372 2092 370 222 370 224 405 224 420 2246 422 2249 401 2246 372 2230 372"/></Shape>
            <String CONTENT="Изъявив свое удовольствие, что сапоги пришлись хорошо, господин Голядкин спросил чаю,"
                    HPOS="222"
                    VPOS="370"
                    WIDTH="2027"
                    HEIGHT="52"
                    WC="0.9998581823180703"></String>
          </TextLine>
          <TextLine ID="eSc_line_1b2a9d0a"
                    TAGREFS="LT1379"
                    BASELINE="226 467 2253 463" 
                    HPOS="224"
                    VPOS="428"
                    WIDTH="2029"
                    HEIGHT="61">
            <Shape><Polygon POINTS="226 467 226 489 2251 479 2253 463 2249 436 516 428 514 428 224 438 226 467"/></Shape>
            <String CONTENT="умываться и бриться. Обрился он весьма тщательно и таким же образом вымылся, хлебнул"
                    HPOS="224"
                    VPOS="428"
                    WIDTH="2029"
                    HEIGHT="61"
                    WC="0.9996225010781061"></String>
          </TextLine>
          <TextLine ID="eSc_line_a21f7a7c"
                    TAGREFS="LT1379"
                    BASELINE="228 528 2253 524" 
                    HPOS="226"
                    VPOS="496"
                    WIDTH="2027"
                    HEIGHT="51">
            <Shape><Polygon POINTS="228 528 228 547 2251 543 2253 524 2247 496 226 498 228 528"/></Shape>
            <String CONTENT="чаю наскоро и приступил к своему главному, окончательному облачению: надел панталоны"
                    HPOS="226"
                    VPOS="496"
                    WIDTH="2027"
                    HEIGHT="51"
                    WC="0.9999431414263589"></String>
          </TextLine>
          <TextLine ID="eSc_line_76bad33a"
                    TAGREFS="LT1379"
                    BASELINE="224 592 2253 588" 
                    HPOS="222"
                    VPOS="561"
                    WIDTH="2031"
                    HEIGHT="45">
            <Shape><Polygon POINTS="224 592 224 606 2251 602 2253 588 2247 561 222 563 224 592"/></Shape>
            <String CONTENT="почти совершенно новые; потом манишку с бронзовыми пуговками, жилетку с весьма"
                    HPOS="222"
                    VPOS="561"
                    WIDTH="2031"
                    HEIGHT="45"
                    WC="0.9994758596787086"></String>
          </TextLine>
          <TextLine ID="eSc_line_22412724"
                    TAGREFS="LT1379"
                    BASELINE="224 654 2251 650" 
                    HPOS="222"
                    VPOS="621"
                    WIDTH="2029"
                    HEIGHT="53">
            <Shape><Polygon POINTS="224 654 224 674 2249 674 2251 650 2246 621 222 623 224 654"/></Shape>
            <String CONTENT="яркими и приятными цветочками; на шею повязал пестрый шелковый галстух и, наконец,"
                    HPOS="222"
                    VPOS="621"
                    WIDTH="2029"
                    HEIGHT="53"
                    WC="0.9999605191916954"></String>
          </TextLine>
          <TextLine ID="eSc_line_1102ceb3"
                    TAGREFS="LT1379"
                    BASELINE="224 717 2251 713" 
                    HPOS="222"
                    VPOS="684"
                    WIDTH="2029"
                    HEIGHT="50">
            <Shape><Polygon POINTS="224 717 224 734 2249 730 2251 713 2246 684 222 686 224 717"/></Shape>
            <String CONTENT="натянул вицмундир, тоже новехонький и тщательно вычищенный. Одеваясь, он несколько раз"
                    HPOS="222"
                    VPOS="684"
                    WIDTH="2029"
                    HEIGHT="50"
                    WC="0.9883999270062114"></String>
          </TextLine>
          <TextLine ID="eSc_line_0c2948e9"
                    TAGREFS="LT1379"
                    BASELINE="224 779 2249 779" 
                    HPOS="224"
                    VPOS="750"
                    WIDTH="2025"
                    HEIGHT="49">
            <Shape><Polygon POINTS="224 779 224 793 2247 799 2249 779 2249 750 224 750 224 779"/></Shape>
            <String CONTENT="с любовью взглядывал на свои сапоги, поминутно приподымал то ту, то другую ногу,"
                    HPOS="224"
                    VPOS="750"
                    WIDTH="2025"
                    HEIGHT="49"
                    WC="0.9979158528149128"></String>
          </TextLine>
          <TextLine ID="eSc_line_ff4575f7"
                    TAGREFS="LT1379"
                    BASELINE="224 841 2253 841" 
                    HPOS="224"
                    VPOS="810"
                    WIDTH="2029"
                    HEIGHT="47">
            <Shape><Polygon POINTS="224 841 224 857 2253 857 2253 841 2253 810 224 810 224 841"/></Shape>
            <String CONTENT="любовался фасоном и что-то всë шептал себе под нос, изредка подмигивая своей думке"
                    HPOS="224"
                    VPOS="810"
                    WIDTH="2029"
                    HEIGHT="47"
                    ></String>
          </TextLine>
          <TextLine ID="eSc_line_3f5e8c95"
                    TAGREFS="LT1379"
                    BASELINE="224 904 2251 904" 
                    HPOS="224"
                    VPOS="873"
                    WIDTH="2027"
                    HEIGHT="48">
            <Shape><Polygon POINTS="224 904 224 919 2249 921 2251 904 2251 873 224 873 224 904"/></Shape>
            <String CONTENT="выразительною гримаскою. Впрочем, в это утро господин Голядкин был крайне рассеян,"
                    HPOS="224"
                    VPOS="873"
                    WIDTH="2027"
                    HEIGHT="48"
                    WC="0.995684018949183"></String>
          </TextLine>
          <TextLine ID="eSc_line_01bbf798"
                    TAGREFS="LT1379"
                    BASELINE="224 966 2251 966" 
                    HPOS="224"
                    VPOS="935"
                    WIDTH="2027"
                    HEIGHT="49">
            <Shape><Polygon POINTS="224 966 224 984 2251 984 2251 966 2251 935 224 935 224 966"/></Shape>
            <String CONTENT="потому что почти не заметил улыбочек и гримас на свой счет помогавшего ему одеваться"
                    HPOS="224"
                    VPOS="935"
                    WIDTH="2027"
                    HEIGHT="49"
                    WC="0.9987270072812126"></String>
          </TextLine>
          <TextLine ID="eSc_line_a04b28c3"
                    TAGREFS="LT1379"
                    BASELINE="224 1029 2251 1025" 
                    HPOS="222"
                    VPOS="993"
                    WIDTH="2029"
                    HEIGHT="53">
            <Shape><Polygon POINTS="224 1029 224 1046 2249 1042 2251 1025 2247 997 222 993 224 1029"/></Shape>
            <String CONTENT="Петрушки. Наконец справив всë, что следовало, совершенно одевшись, господин Голядкин"
                    HPOS="222"
                    VPOS="993"
                    WIDTH="2029"
                    HEIGHT="53"
                    ></String>
          </TextLine>
          <TextLine ID="eSc_line_152f709e"
                    TAGREFS="LT1379"
                    BASELINE="224 1091 2253 1091" 
                    HPOS="224"
                    VPOS="1062"
                    WIDTH="2029"
                    HEIGHT="46">
            <Shape><Polygon POINTS="224 1091 224 1108 2253 1108 2253 1091 2253 1062 224 1062 224 1091"/></Shape>
            <String CONTENT="положил в карман свой бумажник, полюбовался окончательно на Петрушку, надевшего"
                    HPOS="224"
                    VPOS="1062"
                    WIDTH="2029"
                    HEIGHT="46"
                    WC="0.9938707313960111"></String>
          </TextLine>
          <TextLine ID="eSc_line_53c4f8c9"
                    TAGREFS="LT1379"
                    BASELINE="224 1153 2253 1153" 
                    HPOS="224"
                    VPOS="1124"
                    WIDTH="2029"
                    HEIGHT="47">
            <Shape><Polygon POINTS="224 1153 224 1171 2253 1171 2253 1153 2253 1124 224 1124 224 1153"/></Shape>
            <String CONTENT="сапоги и бывшего, таким образом, тоже в совершенной готовности, и, заметив, что всë уже"
                    HPOS="224"
                    VPOS="1124"
                    WIDTH="2029"
                    HEIGHT="47"
                    ></String>
          </TextLine>
          <TextLine ID="eSc_line_96b58ccd"
                    TAGREFS="LT1379"
                    BASELINE="224 1216 2253 1216" 
                    HPOS="224"
                    VPOS="1186"
                    WIDTH="2029"
                    HEIGHT="47">
            <Shape><Polygon POINTS="224 1216 224 1233 2253 1233 2253 1216 2253 1186 224 1186 224 1216"/></Shape>
            <String CONTENT="сделано и ждать уже более нечего, торопливо, суетливо, с маленьким трепетанием сердца"
                    HPOS="224"
                    VPOS="1186"
                    WIDTH="2029"
                    HEIGHT="47"
                    WC="0.9998561887180104"></String>
          </TextLine>
          <TextLine ID="eSc_line_05e68477"
                    TAGREFS="LT1379"
                    BASELINE="224 1278 2251 1274" 
                    HPOS="222"
                    VPOS="1241"
                    WIDTH="2029"
                    HEIGHT="53">
            <Shape><Polygon POINTS="224 1278 224 1294 2249 1292 2251 1274 2247 1249 255 1241 253 1241 251 1241 222 1251 224 1278"/></Shape>
            <String CONTENT="сбежал с своей лестницы. Голубая извозчичья карета, с какими-то гербами, с громом"
                    HPOS="222"
                    VPOS="1241"
                    WIDTH="2029"
                    HEIGHT="53"
                    WC="0.99485914869073"></String>
          </TextLine>
          <TextLine ID="eSc_line_22ab86b9"
                    TAGREFS="LT1379"
                    BASELINE="224 1336 2251 1340" 
                    HPOS="222"
                    VPOS="1307"
                    WIDTH="2029"
                    HEIGHT="49">
            <Shape><Polygon POINTS="224 1336 222 1352 2247 1356 2251 1340 2249 1311 224 1307 224 1336"/></Shape>
            <String CONTENT="подкатилась к крыльцу. Петрушка, перемигиваясь с извозчиком и с кое-какими зеваками,"
                    HPOS="222"
                    VPOS="1307"
                    WIDTH="2029"
                    HEIGHT="49"
                    WC="0.9974435425940014"></String>
          </TextLine>
          <TextLine ID="eSc_line_b1945106"
                    TAGREFS="LT1379"
                    BASELINE="226 1407 2249 1401" 
                    HPOS="224"
                    VPOS="1372"
                    WIDTH="2025"
                    HEIGHT="54">
            <Shape><Polygon POINTS="226 1407 226 1426 2247 1424 2249 1401 2244 1372 224 1375 226 1407"/></Shape>
            <String CONTENT="усадил своего барина в карету; непривычным голосом и едва сдерживая дурацкий смех,"
                    HPOS="224"
                    VPOS="1372"
                    WIDTH="2025"
                    HEIGHT="54"
                    WC="0.9937039679143487"></String>
          </TextLine>
          <TextLine ID="eSc_line_ea6e153d"
                    TAGREFS="LT1379"
                    BASELINE="224 1463 2249 1467" 
                    HPOS="222"
                    VPOS="1434"
                    WIDTH="2027"
                    HEIGHT="53">
            <Shape><Polygon POINTS="224 1463 222 1475 241 1487 243 1487 245 1487 2247 1483 2249 1467 2247 1438 224 1434 224 1463"/></Shape>
            <String CONTENT="крикнул: «Пошел!», вскочил на запятки, и всë это, с шумом и громом, звеня и треща,"
                    HPOS="222"
                    VPOS="1434"
                    WIDTH="2027"
                    HEIGHT="53"
                    ></String>
          </TextLine>
          <TextLine ID="eSc_line_818e59b2"
                    TAGREFS="LT1379"
                    BASELINE="224 1527 2251 1527" 
                    HPOS="224"
                    VPOS="1498"
                    WIDTH="2027"
                    HEIGHT="49">
            <Shape><Polygon POINTS="224 1527 224 1547 2251 1547 2251 1527 2251 1498 224 1498 224 1527"/></Shape>
            <String CONTENT="покатилось на Невский проспект. Только что голубой экипаж успел выехать за ворота, как"
                    HPOS="224"
                    VPOS="1498"
                    WIDTH="2027"
                    HEIGHT="49"
                    WC="0.9938695271347844"></String>
          </TextLine>
          <TextLine ID="eSc_line_31b0be3b"
                    TAGREFS="LT1379"
                    BASELINE="224 1590 2070 1590" 
                    HPOS="224"
                    VPOS="1561"
                    WIDTH="1846"
                    HEIGHT="48">
            <Shape><Polygon POINTS="224 1590 224 1607 2068 1609 2070 1590 2070 1561 224 1561 224 1590"/></Shape>
            <String CONTENT="господин Голядкин судорожно потер себе руки и залился тихим, неслышным смехом,"
                    HPOS="224"
                    VPOS="1561"
                    WIDTH="1846"
                    HEIGHT="48"
                    WC="0.9965840753836509"></String>
          </TextLine>
          <TextLine ID="eSc_line_e98e8491"
                    TAGREFS="LT1379"
                    BASELINE="1193 1652 1286 1648" 
                    HPOS="1189"
                    VPOS="1615"
                    WIDTH="97"
                    HEIGHT="59">
            <Shape><Polygon POINTS="1193 1652 1193 1666 1238 1674 1240 1674 1241 1674 1286 1662 1286 1648 1280 1615 1189 1617 1193 1652"/></Shape>
            <String CONTENT="150"
                    HPOS="1189"
                    VPOS="1615"
                    WIDTH="97"
                    HEIGHT="59"
                    ></String>
          </TextLine>
          <TextLine ID="eSc_line_30cdfc32"
                    TAGREFS="LT1379"
                    BASELINE="226 1713 2253 1716" 
                    HPOS="224"
                    VPOS="1681"
                    WIDTH="2029"
                    HEIGHT="51">
            <Shape><Polygon POINTS="226 1713 224 1728 2249 1732 2253 1716 2251 1685 226 1681 226 1713"/></Shape>
            <String CONTENT="как человек веселого характера, которому удалось сыграть славную штуку и которой штуке"
                    HPOS="224"
                    VPOS="1681"
                    WIDTH="2029"
                    HEIGHT="51"
                    WC="0.9947518761767897"></String>
          </TextLine>
          <TextLine ID="eSc_line_b18789ab"
                    TAGREFS="LT1379"
                    BASELINE="224 1777 2253 1777" 
                    HPOS="224"
                    VPOS="1748"
                    WIDTH="2029"
                    HEIGHT="48">
            <Shape><Polygon POINTS="224 1777 224 1796 2253 1796 2253 1777 2253 1748 224 1748 224 1777"/></Shape>
            <String CONTENT="он сам рад-радехонек. Впрочем, тотчас же после припадка веселости смех сменился каким-то"
                    HPOS="224"
                    VPOS="1748"
                    WIDTH="2029"
                    HEIGHT="48"
                    WC="0.9975123080340299"></String>
          </TextLine>
          <TextLine ID="eSc_line_99fca280"
                    TAGREFS="LT1379"
                    BASELINE="224 1841 2253 1837" 
                    HPOS="222"
                    VPOS="1808"
                    WIDTH="2031"
                    HEIGHT="51">
            <Shape><Polygon POINTS="224 1841 224 1859 2251 1855 2253 1837 2247 1808 222 1810 224 1841"/></Shape>
            <String CONTENT="странным озабоченным выражением в лице господина Голядкина. Несмотря на то, что время"
                    HPOS="222"
                    VPOS="1808"
                    WIDTH="2031"
                    HEIGHT="51"
                    WC="0.9898970912484562"></String>
          </TextLine>
          <TextLine ID="eSc_line_e27fd9d7"
                    TAGREFS="LT1379"
                    BASELINE="224 1900 2251 1904" 
                    HPOS="222"
                    VPOS="1870"
                    WIDTH="2029"
                    HEIGHT="49">
            <Shape><Polygon POINTS="224 1900 222 1915 2247 1919 2251 1904 2249 1874 224 1870 224 1900"/></Shape>
            <String CONTENT="было сырое и пасмурное, он опустил оба окна кареты и заботливо начал высматривать"
                    HPOS="222"
                    VPOS="1870"
                    WIDTH="2029"
                    HEIGHT="49"
                    WC="0.9987379960071894"></String>
          </TextLine>
          <TextLine ID="eSc_line_3c92b011"
                    TAGREFS="LT1379"
                    BASELINE="226 1964 2253 1964" 
                    HPOS="226"
                    VPOS="1935"
                    WIDTH="2027"
                    HEIGHT="48">
            <Shape><Polygon POINTS="226 1964 226 1983 2253 1983 2253 1964 2253 1935 226 1935 226 1964"/></Shape>
            <String CONTENT="направо и налево прохожих, тотчас принимая приличный и степенный вид, как только"
                    HPOS="226"
                    VPOS="1935"
                    WIDTH="2027"
                    HEIGHT="48"
                    WC="0.9998035974800586"></String>
          </TextLine>
          <TextLine ID="eSc_line_0a82f596"
                    TAGREFS="LT1379"
                    BASELINE="228 2028 2253 2028" 
                    HPOS="228"
                    VPOS="1999"
                    WIDTH="2025"
                    HEIGHT="47">
            <Shape><Polygon POINTS="228 2028 228 2046 2253 2046 2253 2028 2253 1999 228 1999 228 2028"/></Shape>
            <String CONTENT="замечал, что на него кто-нибудь смотрит. На повороте с Литейной на Невский проспект он"
                    HPOS="228"
                    VPOS="1999"
                    WIDTH="2025"
                    HEIGHT="47"
                    WC="0.9923227782859358"></String>
          </TextLine>
          <TextLine ID="eSc_line_592eb4b6"
                    TAGREFS="LT1379"
                    BASELINE="226 2091 2251 2091" 
                    HPOS="226"
                    VPOS="2061"
                    WIDTH="2025"
                    HEIGHT="47">
            <Shape><Polygon POINTS="226 2091 226 2108 2251 2108 2251 2091 2251 2061 226 2061 226 2091"/></Shape>
            <String CONTENT="вздрогнул от одного самого неприятного ощущения и, сморщась, как бедняга, которому"
                    HPOS="226"
                    VPOS="2061"
                    WIDTH="2025"
                    HEIGHT="47"
                    WC="0.9953318281871516"></String>
          </TextLine>
          <TextLine ID="eSc_line_7bdcd909"
                    TAGREFS="LT1379"
                    BASELINE="226 2153 2253 2153" 
                    HPOS="226"
                    VPOS="2124"
                    WIDTH="2027"
                    HEIGHT="47">
            <Shape><Polygon POINTS="226 2153 226 2171 2253 2171 2253 2153 2253 2124 226 2124 226 2153"/></Shape>
            <String CONTENT="наступили нечаянно на мозоль, торопливо, даже со страхом прижался в самый темный уголок"
                    HPOS="226"
                    VPOS="2124"
                    WIDTH="2027"
                    HEIGHT="47"
                    WC="0.9943065547395027"></String>
          </TextLine>
          <TextLine ID="eSc_line_1a6903ea"
                    TAGREFS="LT1379"
                    BASELINE="224 2215 2251 2211" 
                    HPOS="222"
                    VPOS="2184"
                    WIDTH="2029"
                    HEIGHT="47">
            <Shape><Polygon POINTS="224 2215 224 2231 2249 2229 2251 2211 2246 2184 222 2186 224 2215"/></Shape>
            <String CONTENT="своего экипажа. Дело в том, что он встретил двух сослуживцев своих, двух молодых"
                    HPOS="222"
