            <String CONTENT="мальчишки! - начал он рассуждать сам с собою. - Ну, что же такого тут странного?"
                    HPOS="224"
                    VPOS="2554"
                    WIDTH="2027"
                    HEIGHT="51"
                    WC="0.9971361055970192"></String>
