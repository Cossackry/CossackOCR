            <Shape><Polygon POINTS="226 2843 226 2859 2251 2853 2253 2837 2247 2808 224 2812 226 2843"/></Shape>
            <String CONTENT="только...» Господин Голядкин не докончил и обмер. Бойкая пара казанских лошадок, весьма"
                    HPOS="224"
                    VPOS="2808"
                    WIDTH="2029"
                    HEIGHT="51"
                    ></String>
