                    WIDTH="2025"
                    HEIGHT="49">
            <Shape><Polygon POINTS="224 2404 224 2422 2249 2422 2249 2404 2249 2373 224 2373 224 2404"/></Shape>
            <String CONTENT="образом своего сотоварища; даже один из них указал пальцем на господина Голядкина."
                    HPOS="224"
                    VPOS="2373"
                    WIDTH="2025"
                    HEIGHT="49"
